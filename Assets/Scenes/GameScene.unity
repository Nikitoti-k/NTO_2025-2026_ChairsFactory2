  m_Script: {fileID: 11500000, guid: ad906da3c66338444ac09e2373e812ff, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  hintPanel: {fileID: 209348059}
  hintText: {fileID: 2020114527}
  holdAfterSuccess: 1.8
  lookText: "\u0414\u0432\u0438\u0433\u0430\u0439\u0442\u0435 \u043C\u044B\u0448\u043A\u043E\u0439
    - \u043A\u0430\u043C\u0435\u0440\u0430"
  moveText: "WASD - \u0445\u043E\u0434\u044C\u0431\u0430"
  doorText: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435 LMB
    - \u043E\u0442\u043A\u0440\u043E\u0439\u0442\u0435 \u0434\u0432\u0435\u0440\u044C"
  vehicleText: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 E - \u0441\u0435\u0441\u0442\u044C
    \u0432 \u0441\u043D\u0435\u0433\u043E\u0445\u043E\u0434"
  flareText: "\u0411\u0440\u043E\u0441\u044C\u0442\u0435 \u0444\u0430\u043A\u0435\u043B
    \u2014 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 <color=#ffff00>F</color>"
  breakDepositText: "\u041B\u043E\u043C\u0430\u0439\u0442\u0435 \u043B\u0435\u0434\u044F\u043D\u0443\u044E
    \u0437\u0430\u043B\u0435\u0436\u044C \u2014 <color=#ffff00>\u041B\u041A\u041C</color>"
  carryToVehicleText: "\u041E\u0442\u043D\u0435\u0441\u0438\u0442\u0435 \u0434\u043E\u0431\u044B\u0442\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437\u0435\u0446\n\u0432 <color=#ffff00>\u0441\u043D\u0435\u0433\u043E\u0445\u043E\u0434</color>"
  returnToBaseText: "\u0412\u044B \u0441\u043E\u0431\u0440\u0430\u043B\u0438 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u0432.\n<color=#00ff00>\u0412\u0435\u0440\u043D\u0438\u0442\u0435\u0441\u044C
    \u043D\u0430 \u0431\u0430\u0437\u0443 \u0438 \u0438\u0437\u0443\u0447\u0438\u0442\u0435
    \u0438\u0445</color>"
  bringToTableText: "\u0412\u043E\u0437\u044C\u043C\u0438\u0442\u0435 \u043E\u0431\u0440\u0430\u0437\u0435\u0446
    \u0438 \u043E\u0442\u043D\u0435\u0441\u0438\u0442\u0435 \u0435\u0433\u043E\n\u043D\u0430
    <color=#ffff00>\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0441\u0442\u043E\u043B</color>"
  baseReturnPoint: {fileID: 742248460}
  baseReturnDistance: 5
  researchTableHighlight: {fileID: 98591564}
  radioMonologue: {fileID: 1259642625}
  vehicleMineralSnapZone: {fileID: 344416184}
