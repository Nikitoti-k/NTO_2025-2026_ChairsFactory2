--- !u!114 &1259642625
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1259642624}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d82a4383360ce384db9e1eddd5cc00c0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  radioPanel: {fileID: 1939748136}
  radioText: {fileID: 1635613501}
  speakerText: {fileID: 263990899}
  promptText: {fileID: 1651848550}
  charsPerSecond: 45
  monologueSets:
  - speakerName: "\u0420\u0430\u0434\u0438\u043E"
    phrases:
    - "\u041F\u0440\u0438\u0451\u043C... \u041D\u0430 \u0441\u0432\u044F\u0437\u0438
      \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E! \u041C\u044B
      \u0437\u0430\u0441\u0435\u043A\u043B\u0438 \u043C\u0430\u0441\u0448\u0430\u0442\u0431\u043D\u044B\u0439
      \u0437\u0432\u0435\u0437\u0434\u043E\u043F\u0430\u0434 \u0432 \u0442\u0432\u043E\u0451\u043C
      \u0441\u0435\u043A\u0442\u043E\u0440\u0435 \u044D\u0442\u043E\u0439 \u043D\u043E\u0447\u044C\u044E."
    - "\u041C\u043E\u0436\u0435\u0448\u044C \u0441\u044A\u0435\u0437\u0434\u0438\u0442\u044C
      \u043D\u0430 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0433\u0430\u0435\u043C\u044B\u0435
      \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u0438 \u0438\u0437\u0443\u0447\u0438\u0442\u044C
      \u043E\u0431\u0440\u0430\u0437\u0446\u044B \u043C\u0438\u043D\u0435\u0440\u0430\u043B\u043E\u0432
      \u043E\u0442\u0442\u0443\u0434\u0430? "
    - "\u041F\u043E\u043D\u0438\u043C\u0430\u0435\u043C, \u0447\u0442\u043E \u044D\u0442\u043E
      \u043D\u0435 \u0442\u0432\u043E\u044F \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F,
      \u043D\u043E \u043E\u0431\u043B\u043E\u043C\u043A\u0438 \u0441\u043A\u043E\u0440\u043E
      \u043F\u043E\u0433\u043B\u043E\u0442\u0438\u0442 \u0441\u043D\u0435\u0433\u0430
      \u0410\u043D\u0442\u0430\u0440\u043A\u0442\u0438\u0434\u044B, \u0430 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
      \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u043E\u0447\u0435\u043D\u044C
      \u0432\u0430\u0436\u043D\u044B \u0434\u043B\u044F \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438!"
  - speakerName: "\u0420\u0430\u0434\u0438\u043E"
    phrases:
    - "\u041F\u0440\u0438\u0451\u043C... \u041C\u044B \u0432\u0438\u0434\u0438\u043C
      \u043F\u043E \u043A\u0430\u043C\u0435\u0440\u0430\u043C, \u0447\u0442\u043E
      \u0442\u0435\u0431\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0441\u043E\u0431\u0440\u0430\u0442\u044C
      \u043C\u0438\u043D\u0435\u0440\u0430\u043B\u044B - \u043E\u0442\u043B\u0438\u0447\u043D\u043E!"
    - "\u0422\u0435\u043F\u0435\u0440\u044C \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E
      \u043F\u0440\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0438\u0445 - \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u043D\u0430 \u0431\u0430\u0437\u0435."
    - "\u041A\u0430\u043A \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0448\u044C
      \u0432\u0441\u0435 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438
      \u043E\u0431\u0440\u0430\u0437\u0446\u0430 - \u0434\u0435\u043B\u0430\u0439
      \u0432\u044B\u0432\u043E\u0434 \u0447\u0442\u043E \u0437\u0430 \u043C\u0438\u043D\u0435\u0440\u0430\u043B
      \u0438 \u043F\u0440\u0438\u0441\u044B\u043B\u0430\u0439 \u043D\u0430\u043C
      \u043E\u0442\u0447\u0451\u0442."
  tutorialManager: {fileID: 1988298929}
