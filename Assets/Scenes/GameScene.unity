  m_text: "\u0412\u044B \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C \u0432\u044B\u0440\u0432\u0430\u0442\u044C\u0441\u044F
    \u0438\u0437 \u043B\u0435\u0434\u044F\u043D\u043D\u043E\u0433\u043E \u043F\u043B\u0435\u043D\u0430,
    \u043F\u043E\u043A\u0430 \u043D\u0435 \u043A\u043E\u043D\u0447\u0438\u043B\u043E\u0441\u044C
    \u0442\u043E\u043F\u043B\u0438\u0432\u043E \u0432 \u0441\u043D\u0435\u0433\u043E\u0445\u043E\u0434\u0435.\n\n\u0422\u0440\u0438
    \u0447\u0430\u0441\u0430 \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u0430\u043B\u043E
    \u044F\u0441\u043D\u043E: \u0432\u044B \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0438\u0441\u044C.\n\n\u041F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u0435\u0442\u0441\u044F
    \u043D\u043E\u0447\u044C, \u0445\u043E\u043B\u043E\u0434 \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F.\n\n\u0421\u043D\u0435\u0436\u043D\u0430\u044F
    \u043F\u0443\u0441\u0442\u043E\u0448\u044C \u0433\u043B\u043E\u0442\u0430\u0435\u0442
    \u0432\u0430\u0441 \u0431\u0435\u0437 \u043E\u0441\u0442\u0430\u0442\u043A\u0430
    \u2014 \u0431\u0435\u0437 \u043A\u0440\u0438\u043A\u0430, \u0431\u0435\u0437
    \u0441\u043B\u0435\u0434\u0430."
